# Application Settings
APP_NAME=Employee Attendance Management System
APP_ENV=production
SECRET_KEY=change-me-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Admin User
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123

# Company/Clinic Name
COMPANY_NAME=verdebeautyclinic

# Database URL (PostgreSQL inside Docker)
DATABASE_URL=postgresql+psycopg2://postgres:secure_postgres_password_123!@db:5432/attendance_db

# ZKTeco Device Configuration
DEVICE_IP=192.168.1.201
DEVICE_PORT=4370
DEVICE_PASSWORD=
DEVICE_TIMEOUT=10
